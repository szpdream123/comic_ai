{
  "name": "comic-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "dev:phone-auth": "node --import tsx scripts/run-phone-auth-dev-server.mjs",
    "admin:bootstrap": "node --import tsx scripts/bootstrap-admin-account.mjs",
    "admin:qa": "node scripts/admin-browser-qa.mjs",
    "test:admin:ui": "node --test apps/admin/index.test.mjs",
    "test:admin:http": "node --import tsx --test apps/backend/src/entrypoints/tests/admin-platform-http.spec.ts",
    "test:admin:http:auth": "node --import tsx --test apps/backend/src/entrypoints/tests/admin-platform-http.spec.ts --test-name-pattern \"admin shell|admin login|sessions|profile|password\"",
    "smoke:text-gateway": "node --import tsx scripts/run-text-model-gateway-smoke.mjs",
    "worker:generation-outbox": "node --import tsx scripts/run-generation-outbox-dispatcher.mjs",
    "worker:generation-video": "node --import tsx scripts/run-generation-video-worker.mjs"
  },
  "dependencies": {
    "@antv/x6": "^3.1.7",
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/s3-request-presigner": "^3.1054.0",
    "bullmq": "^5.78.0",
    "cos-js-sdk-v5": "^1.10.1",
    "ioredis": "^5.10.1",
    "mammoth": "^1.12.0",
    "openai": "^6.39.1",
    "qcloud-cos-sts": "^3.1.3",
    "tencentcloud-sdk-nodejs-sms": "^4.1.240",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "pg": "^8.21.0",
    "tsx": "^4.22.1"
  }
}
