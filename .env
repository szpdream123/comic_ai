PORT=4310
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/comic_ai_dev

# Tencent COS configuration
MODEL_PROVIDER_MODE=dev
STORAGE_ADAPTER_MODE=cos
STORAGE_PROVIDER=cos
STORAGE_BUCKET=aimanhuadrama-1310122982
STORAGE_REGION=ap-guangzhou
STORAGE_ENDPOINT=https://aimanhuadrama-1310122982.cos.ap-guangzhou.myqcloud.com
STORAGE_COS_SECRET_ID=AKIDaTAdrtiJhtvjIeWDINXggT2MRHtGOHo2
STORAGE_COS_SECRET_KEY=1nJbfV5RgiV9i3A1d1B5j9KFwvnVgQxO
STORAGE_COS_STS_DURATION_SECONDS=1800
STORAGE_SIGNED_URL_EXPIRES_SECONDS=900
STORAGE_OBJECT_ROOT_PREFIX=AIManhuaDrama
STORAGE_OBJECT_DATE_TIMEZONE=Asia/Shanghai
STORAGE_REPAIR_SCHEDULER_ENABLED=false

CREATOR_PAYLOAD_SCHEME=creator
CREATOR_IMAGE_WORKER_ID=creator-image-worker
CREATOR_VIDEO_WORKER_ID=creator-video-worker
CREATOR_EXPORT_WORKER_ID=creator-export-worker
CREATOR_SIGNED_URL_EXPIRES_SECONDS=900

# 模型供应商密钥。
# 模型供应商密钥只放在环境变量里，不写入数据库，不提交真实值。
# GPT Image 2 / OpenAI Images 兼容接口密钥；ai_model_configs 通过 apiKeyEnv=GPT_IMAGE2_API_KEY 读取。
GPT_IMAGE2_API_KEY=sk-3d26600eebe910c41b87397147df4b134f73ae6ca0718c476393184ddee696a6
# Seedance / 火山方舟视频接口密钥；Seedance 配置通过 SEEDANCE_API_KEY_ENV 指向该变量。
VOLCENGINE_ARK_API_KEY=8d4d6149-2353-4808-adeb-e8705f13edf1

# GPT Image 2 图片供应商。
# 开启后，gpt-image-2-cn 图片任务会真实调用 OpenAI Images 兼容接口，并把结果写入平台云存储。
GPT_IMAGE2_PROVIDER_ENABLED=true
GPT_IMAGE2_BASE_URL=https://code.shoestravel.xin
GPT_IMAGE2_ENDPOINT=/v1/images/generations

# Seedance 视频供应商。
# 开启后，seedance-i2v-pro 视频任务会真实调用 Seedance，并把结果写入平台云存储。
SEEDANCE_PROVIDER_ENABLED=true
# Seedance 会读取 SEEDANCE_API_KEY_ENV 指定的环境变量，当前为 VOLCENGINE_ARK_API_KEY。
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com
SEEDANCE_CREATE_TASK_ENDPOINT=/api/v3/contents/generations/tasks
SEEDANCE_QUERY_TASK_ENDPOINT=/api/v3/contents/generations/tasks/{taskId}
SEEDANCE_PROVIDER_MODEL=Doubao-Seedance-2.0-fast
SEEDANCE_API_KEY_ENV=VOLCENGINE_ARK_API_KEY

# Redis / BullMQ 生成队列。
# Redis 只负责 BullMQ 调度；任务状态、快照、积分结算、资产落库仍以 PostgreSQL 为准。
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=comic-ai:dev
BULLMQ_QUEUE_PREFIX=comic-ai-dev
BULLMQ_WORKERS_ENABLED=true
BULLMQ_OUTBOX_DISPATCHER_ENABLED=true
BULLMQ_DEFAULT_REMOVE_ON_COMPLETE_AGE_SECONDS=86400
BULLMQ_DEFAULT_REMOVE_ON_COMPLETE_COUNT=10000
BULLMQ_DEFAULT_REMOVE_ON_FAIL_AGE_SECONDS=604800
BULLMQ_DEFAULT_REMOVE_ON_FAIL_COUNT=50000
GENERATION_SUBMIT_IMAGE_QUEUE=generation-submit-image
GENERATION_SUBMIT_VIDEO_QUEUE=generation-submit-video
GENERATION_POLL_VIDEO_QUEUE=generation-poll-video
GENERATION_FINALIZE_ARTIFACT_QUEUE=generation-finalize-artifact
GENERATION_DEAD_LETTER_QUEUE=generation-dead-letter
GENERATION_OUTBOX_DISPATCH_BATCH_SIZE=50
GENERATION_OUTBOX_DISPATCH_INTERVAL_MS=1000
GENERATION_OUTBOX_RETRY_DELAY_MS=30000
# Redis / BullMQ 修复阈值。
# queued 任务超过该时间可补投 outbox；running Seedance 任务可补投 poll job。
GENERATION_REDIS_REPAIR_STALE_DISPATCH_MS=120000
GENERATION_POLL_VIDEO_INTERVAL_MS=5000
GENERATION_POLL_VIDEO_MAX_ATTEMPTS=120

# BullMQ 视频供应商提交队列限流。
# 控制真正向 Seedance 等视频供应商创建任务的速度，避免瞬间打满供应商侧配额。
GENERATION_SUBMIT_VIDEO_CONCURRENCY=10
GENERATION_SUBMIT_VIDEO_RATE_LIMIT_MAX=10
GENERATION_SUBMIT_VIDEO_RATE_LIMIT_DURATION_MS=1000
# BullMQ 视频供应商轮询队列限流。
# 轮询只查询供应商状态，不搬运大文件；并发仍需按供应商 QPS 限制压测调整。
GENERATION_POLL_VIDEO_CONCURRENCY=40
GENERATION_POLL_VIDEO_RATE_LIMIT_MAX=40
GENERATION_POLL_VIDEO_RATE_LIMIT_DURATION_MS=1000

# BullMQ 产物最终化 / 上传并发。
# 视频产物体积大、占带宽，先按 40 并发运行；压测确认带宽、COS 成功率、Node RSS 稳定后再上调。
GENERATION_FINALIZE_VIDEO_CONCURRENCY=40
# 图片产物体积小，先按 100 并发运行；如机器和 COS 吞吐稳定，可继续上调。
GENERATION_FINALIZE_IMAGE_CONCURRENCY=100
# BullMQ limiter 配置：限制单位时间内进入最终化执行的任务数，避免打满带宽或触发 COS / 供应商限流。
GENERATION_FINALIZE_VIDEO_RATE_LIMIT_MAX=40
GENERATION_FINALIZE_VIDEO_RATE_LIMIT_DURATION_MS=1000
GENERATION_FINALIZE_IMAGE_RATE_LIMIT_MAX=100
GENERATION_FINALIZE_IMAGE_RATE_LIMIT_DURATION_MS=1000

# 模型产物上传 COS 的重试配置。
# 3 表示总尝试次数：首次上传失败后最多再重试 2 次；第 3 次仍失败则任务失败并返还积分。
GENERATION_ARTIFACT_UPLOAD_RETRY_ATTEMPTS=3
# 每次上传失败后的等待时间，保留短延迟以应对 COS 瞬时抖动。
GENERATION_ARTIFACT_UPLOAD_RETRY_DELAY_MS=1000

# 腾讯云短信：是否启用真实短信发送。false 时使用本地开发调试验证码
TENCENT_SMS_ENABLED=false

# 腾讯云短信：SecretId，请在腾讯云访问管理 CAM 中创建
TENCENT_SMS_SECRET_ID=1310122982

# 腾讯云短信：SecretKey，只能写入本地 .env，禁止提交到仓库
TENCENT_SMS_SECRET_KEY=AKIDmrkQuBG8oGizAA0f7ZnocEdqqeGfrrgJ

# 腾讯云短信：短信应用 SDK AppID
TENCENT_SMS_SDK_APP_ID=1401138238

# 腾讯云短信：短信签名名称，例如「漫剧AI」
TENCENT_SMS_SIGN_NAME=「武汉市悠然保洁」

# 腾讯云短信：验证码模板 ID，模板变量建议为 {1}=验证码，{2}=有效分钟数
TENCENT_SMS_TEMPLATE_ID=2657158

# 腾讯云短信：发送区域，中国大陆默认 ap-guangzhou
TENCENT_SMS_REGION=ap-guangzhou
